{
  "manifest_version": 3,
  "name": "The Reverse Turing Test",
  "version": "1.0.0",
  "description": "An AI Drill Sergeant CAPTCHA that thinks YOU are the bot. Prove you're human — or get banned.",
  "permissions": ["storage", "tabs"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": [
        "js/api.js",
        "js/audio.js",
        "js/goldilocks.js",
        "js/levels/level1-images.js",
        "js/levels/level2-words.js",
        "js/levels/level3-pi.js",
        "js/levels/level4-math.js",
        "js/submit-chaos.js",
        "js/decoy-captcha.js",
        "js/overlay.js",
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "assets/icons/icon16.png",
      "48": "assets/icons/icon48.png",
      "128": "assets/icons/icon128.png"
    }
  },
  "icons": {
    "16": "assets/icons/icon16.png",
    "48": "assets/icons/icon48.png",
    "128": "assets/icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "styles/overlay.css",
        "assets/*",
        "assets/recaptcha-logo/RecaptchaLogo.svg.png",
        "fonts/*"
      ],
      "matches": ["<all_urls>"]
    }
  ]
}
