{
  "manifest_version": 3,
  "name": "The Reverse Turing Test",
  "version": "2.0.0",
  "description": "An AI Drill Sergeant CAPTCHA that thinks YOU are the bot. Prove you're human — or get banned.",
  "permissions": ["storage", "tabs"],
  "host_permissions": [
    "https://images.pexels.com/*",
    "https://loremflickr.com/*",
    "https://*.staticflickr.com/*"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self';"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "exclude_matches": ["http://localhost:3000/*", "http://127.0.0.1:3000/*"],
      "js": [
        "js/api.js",
        "js/audio.js",
        "js/goldilocks.js",
        "js/levels/level1-images.js",
        "js/levels/level2-words.js",
        "js/levels/level3-pi.js",
        "js/levels/level-chess.js",
        "js/levels/level4-math.js",
        "js/levels/level5-gesture.js",
        "js/levels/level-body.js",
        "js/submit-chaos.js",
        "js/decoy-captcha.js",
        "js/particles.js",
        "js/overlay.js",
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "assets/icons/icon16.png",
      "48": "assets/icons/icon48.png",
      "128": "assets/icons/icon128.png"
    }
  },
  "icons": {
    "16": "assets/icons/icon16.png",
    "48": "assets/icons/icon48.png",
    "128": "assets/icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "styles/overlay.css",
        "camera.html",
        "js/camera-worker.js",
        "assets/*",
        "assets/models/*",
        "assets/recaptcha-logo/RecaptchaLogo.svg.png",
        "fonts/*",
        "images/poses/*"
      ],
      "matches": ["<all_urls>"]
    }
  ]
}
